{
    "services": {
        "frontend": {
            "root": ".",
            "framework": "vite",
            "buildCommand": "npm install && npm run build",
            "outputDirectory": "dist"
        },
        "backend": {
            "root": "backend",
            "startCommand": "npm install && npm start",
            "envVars": {
                "PORT": "5000",
                "NODE_ENV": "production"
            }
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
